<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_primary">

    
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/card_bg"
        app:layout_constraintTop_toTopOf="parent">

        
        <TextView
            android:id="@+id/progress_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1/10"
            android:textSize="14sp"
            android:textColor="@color/accent_blue"
            android:textStyle="bold" />

        
        <TextView
            android:id="@+id/timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏱ 00:42"
            android:textSize="14sp"
            android:textColor="@color/text_light"
            android:layout_marginEnd="16dp" />

        
        <TextView
            android:id="@+id/points_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+20 pkt"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:background="@drawable/chip_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/action_buttons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/category_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚗ Wiązania chemiczne"
                    android:textSize="12sp"
                    android:textColor="@color/accent_blue"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/level_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Poziom: średni"
                    android:textSize="12sp"
                    android:textColor="@color/text_dimmed" />

            </LinearLayout>

            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/question_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jaka jest wartościowość tlenu w cząsteczce H₂O?"
                    android:textSize="18sp"
                    android:textColor="@color/white"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/options_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                
                <LinearLayout
                    android:id="@+id/option_a"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/option_button_default"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/option_a_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="+1"
                        android:textSize="16sp"
                        android:textColor="@color/white" />

                </LinearLayout>

                
                <LinearLayout
                    android:id="@+id/option_b"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/option_button_default"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="B"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/option_b_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="-2"
                        android:textSize="16sp"
                        android:textColor="@color/white" />

                </LinearLayout>

                
                <LinearLayout
                    android:id="@+id/option_c"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/option_button_default"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="C"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/option_c_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="+2"
                        android:textSize="16sp"
                        android:textColor="@color/white" />

                </LinearLayout>

                
                <LinearLayout
                    android:id="@+id/option_d"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/option_button_default"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="D"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/option_d_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="-1"
                        android:textSize="16sp"
                        android:textColor="@color/white" />

                </LinearLayout>

            </LinearLayout>

            
            <LinearLayout
                android:id="@+id/explanation_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="24sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/explanation_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tlen ma elektronu ujemność 3.44 — przyciąga 2 elektrony od wodoru."
                    android:textSize="14sp"
                    android:textColor="@color/text_light"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    
    <LinearLayout
        android:id="@+id/action_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/card_bg"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_skip"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Pomiń"
            android:textColor="@color/accent_blue"
            android:background="@drawable/button_outline"
            android:layout_marginEnd="8dp"
            android:visibility="visible" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Dalej →"
            android:textColor="@color/white"
            android:background="@drawable/button_primary"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

