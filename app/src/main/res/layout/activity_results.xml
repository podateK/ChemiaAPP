<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark_primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/action_buttons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz ukończony!"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp" />

            
            <FrameLayout
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp">

                
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/score_circle_background" />

                
                <TextView
                    android:id="@+id/score_percentage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="78%"
                    android:textSize="72sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue" />

            </FrameLayout>

            
            <TextView
                android:id="@+id/feedback_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dobra robota! 🎉"
                android:textSize="18sp"
                android:textColor="@color/success_green"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_background"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:id="@+id/correct_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/success_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="poprawne"
                        android:textSize="12sp"
                        android:textColor="@color/text_dimmed" />

                </LinearLayout>

                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_background"
                    android:padding="16dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/wrong_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/error_red" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="błędne"
                        android:textSize="12sp"
                        android:textColor="@color/text_dimmed" />

                </LinearLayout>

                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_background"
                    android:padding="16dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:id="@+id/skipped_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/timer_warning" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="pominięte"
                        android:textSize="12sp"
                        android:textColor="@color/text_dimmed" />

                </LinearLayout>

                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_background"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/time_spent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1:42"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="czas"
                        android:textSize="12sp"
                        android:textColor="@color/text_dimmed" />

                </LinearLayout>

            </LinearLayout>

            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Słaba strona"
                    android:textSize="14sp"
                    android:textColor="@color/text_dimmed"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/weakness_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stechiometria"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/timer_warning"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Powtórz: obliczanie mas molowych"
                    android:textSize="13sp"
                    android:textColor="@color/text_light" />

            </LinearLayout>

            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nowe punkty:"
                    android:textSize="14sp"
                    android:textColor="@color/text_dimmed"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/points_earned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+70 pkt"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/success_green" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    
    <LinearLayout
        android:id="@+id/action_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/card_bg"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_play_again"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Zagraj ponownie"
            android:textColor="@color/white"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_menu"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Menu"
            android:textColor="@color/accent_blue"
            android:background="@drawable/button_outline" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

